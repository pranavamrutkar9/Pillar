# ==============================================================================
# Pillar Environment Variables Template
# Copy this file to .env and fill in the values before running the application.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Application Settings
# ------------------------------------------------------------------------------
# The environment the application is running in (development, test, production)
NODE_ENV="development"

# The port the API server will listen on
PORT="4000"

# The base URL of the Next.js frontend (used for CORS and redirect URLs)
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# The base URL of the API server (used by the frontend to make requests)
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# (Optional) Used by the /api/version health check endpoint
# COMMIT_SHA="abc123def456"
# BUILD_TIME="2023-10-27T10:00:00Z"

# ------------------------------------------------------------------------------
# Database (Neon / PostgreSQL)
# ------------------------------------------------------------------------------
# Connection string for Prisma to connect to the PostgreSQL database
DATABASE_URL="postgres://user:password@host:port/dbname"

# ------------------------------------------------------------------------------
# Redis & BullMQ
# ------------------------------------------------------------------------------
# Connection string for the Redis server used by BullMQ and WebSockets
REDIS_URL="redis://localhost:6379"

# ------------------------------------------------------------------------------
# Authentication (NextAuth)
# ------------------------------------------------------------------------------
# The canonical URL of the NextAuth deployment
NEXTAUTH_URL="http://localhost:3000"

# A random string used to hash tokens, sign/encrypt cookies and generate cryptographic keys.
# Generate one via: `openssl rand -base64 32`
NEXTAUTH_SECRET="ybllYNJILhCfnPZmEijHPFH8Byw/61BegkXZcnuGFao="

# GitHub OAuth Credentials
# Create an OAuth app in GitHub Developer Settings
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

# ------------------------------------------------------------------------------
# Email Service (Optional - if implemented)
# ------------------------------------------------------------------------------
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user@example.com"
# SMTP_PASSWORD="password"
# FROM_EMAIL="noreply@pillar.com"
